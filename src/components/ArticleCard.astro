---
import { formatDate } from '../lib/utils';

interface Props {
  title: string;
  description: string;
  href: string;
  pubDate: Date;
  image?: string;
  imageAlt?: string;
}

const { title, description, href, pubDate, image, imageAlt } = Astro.props;
---

<article class="border-border bg-surface group flex h-full flex-col overflow-hidden rounded-lg border shadow-sm transition-shadow hover:shadow-md">
  {
    image && (
      <a href={href} class="bg-surface-muted block overflow-hidden" tabindex="-1" aria-hidden="true">
        <img
          src={image}
          alt={imageAlt ?? title}
          width={360}
          height={225}
          class="aspect-[16/10] w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }
  <div class="flex flex-1 flex-col p-5">
    <time datetime={pubDate.toISOString()} class="text-ink-muted mb-2 text-xs font-medium uppercase tracking-wide">
      {formatDate(pubDate)}
    </time>
    <h2 class="mb-2 text-lg leading-snug">
      <a href={href} class="text-ink group-hover:text-brand-700 no-underline transition-colors">
        {title}
      </a>
    </h2>
    <p class="text-ink-muted line-clamp-3 flex-1 text-sm leading-relaxed">{description}</p>
    <a
      href={href}
      class="text-brand-700 hover:text-brand-600 mt-4 inline-flex items-center text-sm font-medium no-underline"
      aria-label={`Read more: ${title}`}
    >
      Read more
      <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
