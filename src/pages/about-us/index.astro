---
import Layout from '../../layouts/Layout.astro';
import MarkdownContent from '../../components/MarkdownContent.astro';
import pageData from '../../data/pages/about-us.json';
---

<Layout
  title={pageData.title}
  description={pageData.description}
  canonical="https://vegantattoostudios.com/about-us/"
  modifiedTime={pageData.modified}
>
  <article class="container-site py-10 md:py-14">
    <header class="mx-auto mb-8 max-w-3xl">
      <h1 class="text-ink">About Vegan Tattoo Studios</h1>
    </header>
    <div class="mx-auto max-w-3xl">
      <MarkdownContent content={pageData.content} />
    </div>
  </article>
</Layout>
