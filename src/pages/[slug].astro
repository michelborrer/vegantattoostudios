---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Prose from '../components/Prose.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { formatDate } from '../lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, author, image, imageAlt } = post.data;
const seoTitle = `${title} | Vegan Tattoo Studios`;

const relatedPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout
  title={seoTitle}
  description={description}
  canonical={`https://vegantattoostudios.com/${post.id}/`}
  image={image}
  imageAlt={imageAlt}
  type="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={(updatedDate ?? pubDate).toISOString()}
  author={author}
  breadcrumbLabel={title}
>
  <article class="container-site py-10 md:py-14">
    <nav aria-label="Breadcrumb" class="mx-auto mb-6 max-w-3xl">
      <ol class="text-ink-muted flex flex-wrap items-center gap-1 text-sm">
        <li><a href="/" class="hover:text-brand-700 no-underline">Home</a></li>
        <li aria-hidden="true" class="px-1">/</li>
        <li aria-current="page" class="text-ink line-clamp-1">{title}</li>
      </ol>
    </nav>
    <header class="mx-auto mb-8 max-w-3xl text-center">
      <time
        datetime={pubDate.toISOString()}
        class="text-ink-muted mb-3 block text-sm font-medium uppercase tracking-wide"
      >
        {formatDate(pubDate)}
      </time>
      <h1 class="text-ink mb-4">{title}</h1>
      {description && <p class="text-ink-muted text-lg">{description}</p>}
      <p class="text-ink-muted mt-4 text-sm">
        By <span class="text-ink font-medium">{author ?? 'Vegan Tattoo Studios'}</span>
        {updatedDate && (
          <>
            {' · '}Updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
          </>
        )}
      </p>
    </header>

    {
      image && (
        <figure class="mx-auto mb-10 max-w-4xl">
          <img
            src={image}
            alt={imageAlt ?? title}
            width={960}
            height={600}
            class="border-border w-full rounded-xl border shadow-sm"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </figure>
      )
    }

    <Prose class="mx-auto max-w-3xl">
      <Content />
    </Prose>
  </article>

  {
    relatedPosts.length > 0 && (
      <section
        class="bg-surface-muted border-border border-t py-12 md:py-16"
        aria-labelledby="related-heading"
      >
        <div class="container-site">
          <h2 id="related-heading" class="text-ink mb-8 text-2xl font-semibold md:text-3xl">
            Related articles
          </h2>
          <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {relatedPosts.map((related) => (
              <ArticleCard
                title={related.data.title}
                description={related.data.description}
                href={`/${related.id}/`}
                pubDate={related.data.pubDate}
                image={related.data.image}
                imageAlt={related.data.imageAlt}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }
</Layout>
