---
import Layout from '../../layouts/Layout.astro';
import LocationMapPlaceholder from '../../components/LocationMapPlaceholder.astro';
import TattooStudioRow from '../../components/TattooStudioRow.astro';
import studios from '../../data/studios.json';

const sortedStudios = [...studios].sort((a, b) =>
  a.name.localeCompare(b.name, undefined, { sensitivity: 'base' }),
);
---

<Layout
  title="Store Locator | Vegan Tattoo Studios"
  description="Find vegan tattoo studios and artists worldwide. Browse our directory of cruelty-free tattoo shops across the globe."
  canonical="https://vegantattoostudios.com/store-locator/"
  type="website"
  schema={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Vegan Tattoo Studios Directory',
    description: 'Directory of vegan tattoo studios worldwide',
    url: 'https://vegantattoostudios.com/store-locator/',
    mainEntity: {
      '@type': 'ItemList',
      numberOfItems: sortedStudios.length,
      itemListElement: sortedStudios.map((studio, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'TattooParlor',
          name: studio.name,
          address: {
            '@type': 'PostalAddress',
            streetAddress: studio.street,
            addressLocality: studio.city,
            addressRegion: studio.region,
            postalCode: studio.zip,
            addressCountry: studio.country,
          },
          telephone: studio.phone || undefined,
          url: studio.website || undefined,
        },
      })),
    },
  }}
>
  <section class="bg-surface-muted border-border border-b py-10 md:py-14">
    <div class="container-site">
      <h1 class="text-ink mb-3">Tattoo Studios</h1>
      <p class="text-ink-muted max-w-2xl">
        Browse vegan-friendly tattoo studios from around the world. Each listing includes location,
        contact details, and website links where available.
      </p>
    </div>
  </section>

  <div class="container-site py-10 md:py-14">
    <LocationMapPlaceholder studios={sortedStudios} />

    <section aria-labelledby="studios-heading">
      <h2 id="studios-heading" class="text-ink mb-6 text-xl font-semibold">
        All Studios ({sortedStudios.length})
      </h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {sortedStudios.map((studio) => <TattooStudioRow studio={studio} />)}
      </div>
    </section>
  </div>
</Layout>
