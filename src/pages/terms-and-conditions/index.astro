---
import Layout from '../../layouts/Layout.astro';
import MarkdownContent from '../../components/MarkdownContent.astro';
import pageData from '../../data/pages/terms-and-conditions.json';
---

<Layout
  title="Terms and Conditions | Vegan Tattoo Studios"
  description="Terms and conditions for using the Vegan Tattoo Studios website."
  canonical="https://vegantattoostudios.com/terms-and-conditions/"
  modifiedTime={pageData.modified}
>
  <article class="container-site py-10 md:py-14">
    <header class="mx-auto mb-8 max-w-3xl">
      <h1 class="text-ink">Terms and Conditions</h1>
    </header>
    <div class="mx-auto max-w-3xl">
      <MarkdownContent content={pageData.content} />
    </div>
  </article>
</Layout>
