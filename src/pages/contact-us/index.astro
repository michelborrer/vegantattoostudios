---
import Layout from '../../layouts/Layout.astro';
import pageData from '../../data/pages/contact-us.json';
---

<Layout
  title={pageData.title}
  description={pageData.description}
  canonical="https://vegantattoostudios.com/contact-us/"
>
  <article class="container-site py-10 md:py-14">
    <header class="mx-auto mb-8 max-w-3xl">
      <h1 class="text-ink">Contact Us</h1>
    </header>
    <div class="prose mx-auto max-w-3xl">
      <p>
        If you are a tattoo studio or artist and want to be added to our directory, please reach
        out with your address, contact details, links to social networks, a short bio, and photos
        of your best work. Listing is completely free.
      </p>
      <p>
        For any questions about vegan tattoos or this website, we welcome your message. Use the
        contact details below and we will get back to you as soon as possible.
      </p>
      <div class="border-border bg-surface-muted not-prose mt-8 rounded-lg border p-6">
        <h2 class="text-ink mb-3 text-lg font-semibold">Get in touch</h2>
        <p class="text-ink-muted text-sm">
          Contact form integration will be connected in a future update. In the meantime, please
          include your name, email, phone, and message when reaching out.
        </p>
      </div>
    </div>
  </article>
</Layout>
