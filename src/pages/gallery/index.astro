---
import Layout from '../../layouts/Layout.astro';
import pageData from '../../data/pages/gallery.json';
---

<Layout
  title={pageData.title}
  description={pageData.description}
  canonical="https://vegantattoostudios.com/gallery/"
  modifiedTime={pageData.modified}
>
  <article class="container-site py-10 md:py-14">
    <header class="mx-auto mb-8 max-w-3xl text-center">
      <h1 class="text-ink mb-3">Vegan Tattoos Gallery</h1>
      <p class="text-ink-muted">{pageData.description}</p>
    </header>

    <figure class="mx-auto max-w-4xl">
      <img
        src="/uploads/2021/07/коллаж2_960x0_c37-1160x500.jpg"
        alt="Vegan tattoo gallery collage"
        width={1160}
        height={500}
        class="border-border w-full rounded-xl border shadow-md"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <figcaption class="text-ink-muted mt-3 text-center text-sm">
        A collection of vegan tattoo artwork from artists around the world.
      </figcaption>
    </figure>
  </article>
</Layout>
